@model EmployeeManagementSystem.Models.Department
@{
    ViewData["Title"] = "Departman Düzenle";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0 fw-semibold">Departman Düzenle</h4>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="DepartmentId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-semibold">Departman Adı</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i>Güncelle
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
