@{
    ViewData["Title"] = "Personel Yönetim Sistemi";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-7 text-center">
        <div class="mb-4">
            <i class="bi bi-people-fill display-1 text-primary opacity-75"></i>
        </div>
        <h1 class="fw-bold mb-3">Personel Yönetim Sistemi</h1>
        <p class="lead text-muted mb-5">
            Çalışanlarınızı, departmanlarınızı ve pozisyonlarınızı tek bir yerden yönetin.
        </p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-5">
            <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
        </a>
    </div>
</div>
