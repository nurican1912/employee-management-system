@model IEnumerable<EmployeeManagementSystem.Models.Employee>
@{
    ViewData["Title"] = "Çalışanlar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold"><i class="bi bi-people me-2 text-muted"></i>Çalışanlar</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Yeni Çalışan
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label small text-muted mb-1">Ad, soyad veya e-posta ile ara</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" class="form-control border-start-0" placeholder="Ara..."
                           value="@ViewBag.Search" />
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label small text-muted mb-1">Departman</label>
                <select name="departmentId" class="form-select" asp-items="ViewBag.Departments">
                    <option value="">Tüm Departmanlar</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary w-100">
                    <i class="bi bi-funnel me-1"></i>Filtrele
                </button>
                @if (ViewBag.Search != null || ViewBag.DepartmentId != null)
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg"></i>
                    </a>
                }
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Ad Soyad</th>
                            <th>E-posta</th>
                            <th>Telefon</th>
                            <th>Departman</th>
                            <th>Pozisyon</th>
                            <th>Maaş</th>
                            <th class="pe-4 text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-medium">@item.FirstName @item.LastName</div>
                                    <div class="small text-muted">@item.BirthDate.ToString("dd.MM.yyyy")</div>
                                </td>
                                <td class="text-muted">@item.Email</td>
                                <td class="text-muted">@item.Phone</td>
                                <td><span class="badge bg-primary-subtle text-primary">@item.Department?.Name</span></td>
                                <td class="text-muted">@item.Position?.Name</td>
                                <td class="fw-medium">@item.Salary.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</td>
                                <td class="pe-4 text-end">
                                    <a asp-action="Details" asp-route-id="@item.EmployeeId"
                                       class="btn btn-sm btn-outline-secondary me-1" title="Detay">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.EmployeeId"
                                       class="btn btn-sm btn-outline-warning me-1" title="Düzenle">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            title="Sil"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal"
                                            data-employee-id="@item.EmployeeId"
                                            data-employee-name="@item.FirstName @item.LastName">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-search fs-1 d-block mb-3 opacity-25"></i>
                @if (ViewBag.Search != null || ViewBag.DepartmentId != null)
                {
                    <p>Arama kriterlerine uygun çalışan bulunamadı.</p>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Filtreyi Temizle</a>
                }
                else
                {
                    <p>Henüz çalışan eklenmemiş.</p>
                    <a asp-action="Create" class="btn btn-primary btn-sm">İlk çalışanı ekle</a>
                }
            </div>
        }
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="bi bi-exclamation-triangle me-2"></i>Çalışanı Sil
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4">
                <p class="mb-1"><strong id="modalEmployeeName"></strong> adlı çalışan silinecek.</p>
                <p class="text-muted small mb-0">Bu işlem geri alınamaz.</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">İptal</button>
                <form id="deleteForm" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Evet, Sil
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('deleteModal').addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-employee-id');
            var name = button.getAttribute('data-employee-name');
            document.getElementById('modalEmployeeName').textContent = name;
            document.getElementById('deleteForm').action = '/Employee/DeleteConfirmed/' + id;
        });
    </script>
}
