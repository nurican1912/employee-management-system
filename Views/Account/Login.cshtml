@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="text-center mb-4">
            <i class="bi bi-people-fill display-5 text-primary"></i>
            <h4 class="mt-2 fw-semibold">Personel Yönetim Sistemi</h4>
            <p class="text-muted small">Devam etmek için giriş yapın</p>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2 small d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-exclamation-circle-fill"></i>@ViewBag.Error
                    </div>
                }

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="username" class="form-label fw-semibold">Kullanıcı Adı</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person text-muted"></i></span>
                            <input type="text" name="username" id="username" class="form-control border-start-0" placeholder="Kullanıcı adı" required autofocus />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label for="password" class="form-label fw-semibold">Şifre</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock text-muted"></i></span>
                            <input type="password" name="password" id="password" class="form-control border-start-0" placeholder="Şifre" required />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Giriş Yap
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
